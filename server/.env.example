# Server
PORT=3000

# Database —— 按 URL 协议头自动选择数据库类型(postgres / mysql / mariadb / sqlite)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/monitor
# MySQL:  DATABASE_URL=mysql://root:root@localhost:3306/monitor
# SQLite: DATABASE_URL=sqlite:./data/monitor.db

# Auth
ADMIN_USER=admin
ADMIN_PASS=changeme
JWT_SECRET=your-jwt-secret-change-in-production
